{
  "name": "levelojs",
  "version": "2.1.0",
  "description": "A core building library for the Levelo JS framework, providing reactive primitives and a Direct Real DOM-based rendering interface for optimized UI construction.",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "levelo",
    "levelojs",
    "framework",
    "reactive",
    "real-dom",
    "jsx",
    "frontend",
    "ultra-fast",
    "no-vdom",
    "ui-builder",
    "core",
    "Levelo Js",
    "Motion Mind"
  ],
  "author": "MotionMind2007",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MotionMind2007/Levelo-Js.git"
  },
  "bugs": {
    "url": "https://github.com/MotionMind2007/Levelo-Js/issues"
  },
  "homepage": "https://levelojs.motionmind.me",
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  }
}
